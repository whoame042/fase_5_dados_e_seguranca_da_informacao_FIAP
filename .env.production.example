# ==============================================================================
# CONFIGURAÇÕES DO BANCO DE DADOS - POSTGRESQL (PRODUÇÃO)
# ==============================================================================

# Nome do banco de dados
POSTGRES_DB=vehicle_resale_prod

# Usuário do PostgreSQL
POSTGRES_USER=vehicle_user

# Senha do PostgreSQL (ALTERAR PARA SENHA FORTE)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Porta externa do PostgreSQL
POSTGRES_PORT=5432

# Porta interna do PostgreSQL (não alterar)
POSTGRES_INTERNAL_PORT=5432

# ==============================================================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ==============================================================================

# URL de conexão com o banco de dados
DB_URL=jdbc:postgresql://postgres:5432/vehicle_resale_prod

# Usuário do banco
DB_USERNAME=vehicle_user

# Senha do banco (ALTERAR PARA SENHA FORTE)
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ==============================================================================
# CONFIGURAÇÕES DO QUARKUS (PRODUÇÃO)
# ==============================================================================

# Porta HTTP da aplicação
QUARKUS_HTTP_PORT=8080

# Porta externa da aplicação
APP_PORT=8080

# Estratégia de geração do schema do banco (IMPORTANTE: usar 'validate' ou 'none' em produção)
QUARKUS_HIBERNATE_ORM_DATABASE_GENERATION=validate

# Desabilitar log de SQL em produção
QUARKUS_HIBERNATE_ORM_LOG_SQL=false

# Nível de log da aplicação (usar WARN ou ERROR em produção)
QUARKUS_LOG_LEVEL=WARN

# Nível de log específico para o pacote com.vehicleresale
QUARKUS_LOG_CATEGORY_COM_VEHICLERESALE_LEVEL=INFO

# ==============================================================================
# CONFIGURAÇÕES DE CONTAINER
# ==============================================================================

# Nome do container PostgreSQL
POSTGRES_CONTAINER_NAME=vehicle-resale-postgres-prod

# Nome do container da aplicação
APP_CONTAINER_NAME=vehicle-resale-api-prod

# Nome da rede Docker
DOCKER_NETWORK_NAME=vehicle-resale-network-prod

# ==============================================================================
# CONFIGURAÇÕES OPCIONAIS
# ==============================================================================

# Ambiente de execução
ENVIRONMENT=prod

# Timezone
TZ=America/Sao_Paulo
