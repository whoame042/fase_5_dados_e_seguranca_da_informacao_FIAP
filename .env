# ==============================================================================
# CONFIGURAÇÕES DO BANCO DE DADOS - POSTGRESQL
# ==============================================================================

# Nome do banco de dados
POSTGRES_DB=vehicle_resale

# Usuário do PostgreSQL
POSTGRES_USER=postgres

# Senha do PostgreSQL
POSTGRES_PASSWORD=postgres123

# Porta externa do PostgreSQL (para evitar conflito com instalações locais)
POSTGRES_PORT=5433

# Porta interna do PostgreSQL (não alterar)
POSTGRES_INTERNAL_PORT=5432

# ==============================================================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ==============================================================================

# URL de conexão com o banco de dados
# Formato: jdbc:postgresql://<host>:<porta>/<database>
DB_URL=jdbc:postgresql://postgres:5432/vehicle_resale

# Usuário do banco (mesmo que POSTGRES_USER)
DB_USERNAME=postgres

# Senha do banco (mesmo que POSTGRES_PASSWORD)
DB_PASSWORD=postgres123

# ==============================================================================
# CONFIGURAÇÕES DO QUARKUS
# ==============================================================================

# Porta HTTP da aplicação
QUARKUS_HTTP_PORT=8080

# Porta externa da aplicação (mapeamento host:container)
APP_PORT=8080

# Estratégia de geração do schema do banco
# Opções: none, create, drop-and-create, drop, update, validate
QUARKUS_HIBERNATE_ORM_DATABASE_GENERATION=update

# Habilitar log das queries SQL (true/false)
QUARKUS_HIBERNATE_ORM_LOG_SQL=true

# Nível de log da aplicação
# Opções: OFF, FATAL, ERROR, WARN, INFO, DEBUG, TRACE, ALL
QUARKUS_LOG_LEVEL=INFO

# Nível de log específico para o pacote com.vehicleresale
QUARKUS_LOG_CATEGORY_COM_VEHICLERESALE_LEVEL=DEBUG

# ==============================================================================
# CONFIGURAÇÕES DE CONTAINER
# ==============================================================================

# Nome do container PostgreSQL
POSTGRES_CONTAINER_NAME=vehicle-resale-postgres

# Nome do container da aplicação
APP_CONTAINER_NAME=vehicle-resale-api

# Nome da rede Docker
DOCKER_NETWORK_NAME=vehicle-resale-network

# ==============================================================================
# CONFIGURAÇÕES OPCIONAIS
# ==============================================================================

# Ambiente de execução (dev, staging, prod)
ENVIRONMENT=dev

# Timezone
TZ=America/Sao_Paulo
